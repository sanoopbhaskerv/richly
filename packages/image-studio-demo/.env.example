# Optional real LiteRT.js Smart Enhance model configuration.
#
# The demo serves @litertjs/core Wasm files from /litert/wasm/ automatically.
# Put or host a real .tflite model and set the URL below to enable
# "Apply smart enhance" in Image Studio.

VITE_IMAGE_STUDIO_SMART_ENHANCE_MODEL_URL=
VITE_IMAGE_STUDIO_SMART_ENHANCE_LABEL=Smart Enhance
VITE_IMAGE_STUDIO_AI_WASM_URL=/litert/wasm/
VITE_IMAGE_STUDIO_AI_ACCELERATOR=webgpu

# Model-specific tensor contract. Defaults match common NCHW image models.
VITE_IMAGE_STUDIO_SMART_ENHANCE_WIDTH=224
VITE_IMAGE_STUDIO_SMART_ENHANCE_HEIGHT=224
VITE_IMAGE_STUDIO_SMART_ENHANCE_LAYOUT=nchw

# Comma-separated vector output mapping into Image Studio adjustment channels.
VITE_IMAGE_STUDIO_SMART_ENHANCE_CHANNELS=exposure,contrast,saturation,sharpen
VITE_IMAGE_STUDIO_SMART_ENHANCE_OUTPUT_SCALE=1
VITE_IMAGE_STUDIO_SMART_ENHANCE_OUTPUT_CLAMP=1
