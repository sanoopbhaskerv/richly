{
  "name": "@richly/image-studio-demo",
  "private": true,
  "version": "0.0.0",
  "description": "Standalone demo and installable PWA host for Richly Image Studio. Permanently private; never published.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5178 --strictPort",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit --tsBuildInfoFile ../../node_modules/image-studio-demo.app.tsbuildinfo && tsc -p tsconfig.node.json --noEmit --tsBuildInfoFile ../../node_modules/image-studio-demo.node.tsbuildinfo"
  },
  "dependencies": {
    "@litertjs/core": "^2.5.2",
    "@richly/core": "1.0.0",
    "@richly/image-ai-litert": "0.0.0",
    "@richly/image-core": "0.0.0",
    "@richly/image-studio": "0.0.0",
    "@richly/plugin-image-editor": "0.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  }
}
