{
  "name": "@richly/image-studio",
  "private": true,
  "version": "0.0.0",
  "description": "Complete Image Studio editing experience built on the Richly image engine and React primitives. Scaffolding only; not yet published.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanoopbhaskerv/richly.git",
    "directory": "packages/image-studio"
  },
  "homepage": "https://github.com/sanoopbhaskerv/richly#readme",
  "bugs": {
    "url": "https://github.com/sanoopbhaskerv/richly/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./controller": {
      "types": "./dist/controller.d.ts",
      "import": "./dist/controller.js",
      "require": "./dist/controller.cjs"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@richly/image-core": "0.0.0",
    "@richly/image-react": "0.0.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
