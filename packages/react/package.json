{
  "name": "@richly/react",
  "version": "0.3.0",
  "description": "React bindings for Richly, a dependency-free WYSIWYG HTML editor.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanoopbhaskerv/richly.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/sanoopbhaskerv/richly#readme",
  "bugs": {
    "url": "https://github.com/sanoopbhaskerv/richly/issues"
  },
  "keywords": [
    "react",
    "react-editor",
    "rich-text-editor",
    "wysiwyg",
    "wysiwyg-editor",
    "contenteditable",
    "html-editor",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=18.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "yarn build"
  },
  "dependencies": {
    "@richly/core": "^0.3.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "typescript": "^5.5.0"
  }
}
