{
  "name": "@richly/image-core",
  "private": true,
  "version": "0.0.0",
  "description": "Framework-agnostic non-destructive image editing engine for Richly Image Studio. Scaffolding only; not yet published.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanoopbhaskerv/richly.git",
    "directory": "packages/image-core"
  },
  "homepage": "https://github.com/sanoopbhaskerv/richly#readme",
  "bugs": {
    "url": "https://github.com/sanoopbhaskerv/richly/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
